# ProLnk Environment Variables
# Copy to .env and fill in values

# Database (TiDB Cloud - MySQL compatible, serverless)
DATABASE_URL=mysql://user:password@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/prolnk_production?sslMode=REQUIRED

# Auth (Manus OAuth - temporary, replace by Month 2)
OAUTH_SERVER_URL=https://oauth.example.com
VITE_OAUTH_PORTAL_URL=https://portal.example.com

# App
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://prolnk.io

# Email (Resend)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=ProLnk <noreply@prolnk.io>

# Stripe (Stripe Connect for partner payouts)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_CONNECT_PLATFORM_ID=acct_xxxxx

# AI Models
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Monitoring
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# OneSignal (push notifications)
ONESIGNAL_APP_ID=xxxxx
ONESIGNAL_API_KEY=xxxxx

# PostHog (analytics)
POSTHOG_API_KEY=phc_xxxxx
POSTHOG_DISABLED=false

# N8N Webhooks (automation)
N8N_WEBHOOK_BASE_URL=https://prolnk.app.n8n.cloud/webhook

# FSM Integrations (placeholder - configure in setup)
SERVICETITAN_API_SANDBOX=false
SERVICETITAN_API_KEY=xxxxx
SERVICETITAN_API_SECRET=xxxxx
JOBBER_API_KEY=xxxxx
HOUSECALL_PRO_API_KEY=xxxxx

# File Storage (Cloudflare R2 / S3-compatible)
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=prolnk-uploads
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
