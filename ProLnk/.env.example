# ProLnk / TrustyPro — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git

# ─── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://prolnk.io
NODE_ENV=development
PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-64-chars

# Admin detection (owner/admin email address)
OWNER_EMAIL=andrew@prolnk.io

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway MySQL: provided by Railway
# PlanetScale: from their dashboard
DATABASE_URL=mysql://user:password@host:3306/prolnk

# ─── Storage ──────────────────────────────────────────────────────────────────
# For Cloudflare R2:
AWS_ACCESS_KEY_ID=your-r2-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-key
AWS_REGION=auto
S3_BUCKET_NAME=prolnk-photos
S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_CDN_BASE_URL=https://imagedelivery.net/YOUR_HASH

# For private documents bucket (license, COI, etc.)
# S3_PRIVATE_BUCKET_NAME=prolnk-documents

# ─── AI — LLM ─────────────────────────────────────────────────────────────────
# OpenAI (platform.openai.com → API Keys)
OPENAI_API_KEY=sk-...

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio (for Gemini Flash Lite — cheapest Tier 1)
GOOGLE_AI_API_KEY=

# ─── AI — Image Generation ────────────────────────────────────────────────────
# Replicate (replicate.com → Account → API Tokens)
REPLICATE_API_TOKEN=r8_...

# ─── AI — Memory ──────────────────────────────────────────────────────────────
# Zep Cloud (getzep.com)
ZEP_API_KEY=z_...

# Qdrant (cloud.qdrant.io or self-hosted)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Mem0 (mem0.ai or self-hosted)
MEM0_API_KEY=m0-...
# MEM0_HOST=http://localhost:8000  # if self-hosted

# ─── AI — Observability ────────────────────────────────────────────────────────
# Langfuse (cloud.langfuse.com or self-hosted)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Portkey (portkey.ai)
PORTKEY_API_KEY=

# PostHog (posthog.com or self-hosted)
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Payments ─────────────────────────────────────────────────────────────────
# Stripe (dashboard.stripe.com → Developers → API Keys)
# NOTE: Use sk_test_ for development, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_51TCs4b2QWT2AIejI...
STRIPE_PUBLISHABLE_KEY=pk_test_51TCs4b2QWT2AIejI...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Communications ───────────────────────────────────────────────────────────
# Resend (resend.com → API Keys)
RESEND_API_KEY=re_Ms8XvDhM_...
FROM_EMAIL=ProLnk <noreply@prolnk.io>

# Twilio (twilio.com → Console)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX  # Your real 10DLC registered number (NOT +18005551234)

# ─── Verification & Data ──────────────────────────────────────────────────────
# Checkr (checkr.com)
CHECKR_API_KEY=

# Smarty Streets (smartystreets.com)
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# ATTOM Data (api.attomdata.com)
ATTOM_API_KEY=

# ─── Mapping ──────────────────────────────────────────────────────────────────
# Google Maps (console.cloud.google.com)
GOOGLE_MAPS_API_KEY=

# Radar.io (radar.com)
RADAR_SECRET_KEY=

# ─── Integrations ─────────────────────────────────────────────────────────────
# CompanyCam (developers.companycam.com)
COMPANYCAM_CLIENT_ID=
COMPANYCAM_CLIENT_SECRET=

# Jobber (developer.getjobber.com)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=

# ServiceTitan (developer.servicetitan.io)
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=
SERVICETITAN_APP_KEY=

# Lob.com (lob.com)
LOB_API_KEY=

# Tax1099 (tax1099.com)
TAX1099_API_KEY=

# n8n
N8N_WEBHOOK_BASE_URL=https://prolnk.app.n8n.cloud/webhook

# ─── Inngest (background jobs) ────────────────────────────────────────────────
# inngest.com (optional — falls back to direct cron if not set)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Web Push Notifications ───────────────────────────────────────────────────
# Generate with: node -e "const wp = require('web-push'); const keys = wp.generateVAPIDKeys(); console.log(keys);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Manus (DEPRECATED — keep until migration complete) ───────────────────────
# Remove these after migrating to Railway and setting up new auth
# BUILT_IN_FORGE_API_URL=https://forge.manus.ai
# BUILT_IN_FORGE_API_KEY=
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=

# ─── Manus n8n (active) ────────────────────────────────────────────────────────
# Your n8n instance is live at prolnk.app.n8n.cloud
# This stays active regardless of Manus platform migration
