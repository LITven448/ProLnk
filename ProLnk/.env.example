# ProLnk Environment Variables
# Copy to .env and fill in values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Auth
JWT_SECRET=your-secret-key-min-32-chars

# App
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://prolnk.io

# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_KEY=your-publishable-key

# Email (Resend)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=ProLnk <noreply@prolnk.io>

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-xxxxx

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
