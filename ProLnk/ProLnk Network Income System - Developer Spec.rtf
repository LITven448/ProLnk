\pard\pardeftab720\partightenfactor0

\f1\b0\fs24 \cf0 \'95Reads ?ref=XXXXXX from URL on load\
\'95Stores the ref code in localStorage as prolnk_ref_code\
\'95Shows the referring pro's name and trade if the code is valid (call a public tRPC procedure to look up the referrer by code)\
\'95Has a "Join ProLnk" CTA button that starts the enrollment flow\
\'95On enrollment form submit, passes the ref code to network.enroll\
\pard\pardeftab720\sa280\partightenfactor0

\f0\b\fs28 \cf0 Page 2: /dashboard/network \'97 Network Income Dashboard\
\pard\pardeftab720\partightenfactor0

\f1\b0\fs24 \cf0 \'95Calls network.getDashboard\
\'95Shows: referral link with copy button, QR code (generate client-side using qrcode npm package), monthly income breakdown, total downline count, direct referrals count\
\'95Shows a table of recent payout history (calls network.getPayoutHistory)\
\'95Shows income broken out by type: own jobs, network L1, network L2, network L3, photo origination\
\pard\pardeftab720\sa280\partightenfactor0

\f0\b\fs28 \cf0 Page 3: /admin/network \'97 Admin Network Overview\
\pard\pardeftab720\partightenfactor0

\f1\b0\fs24 \cf0 \'95Calls network.adminGetNetworkOverview\
