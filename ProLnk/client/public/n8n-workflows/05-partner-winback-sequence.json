{
  "name": "ProLnk: Partner Win-Back (60-Day Inactive)",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "hours", "hoursInterval": 24 }] }
      },
      "id": "daily-trigger",
      "name": "Daily Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://prolnk.io/api/trpc/admin.getInactivePartners",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Authorization", "value": "Bearer {{ $env.PROLNK_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [{ "name": "json", "value": "{ \"inactiveDays\": 60 }" }]
        }
      },
      "id": "fetch-inactive",
      "name": "Fetch 60-Day Inactive Partners",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "result.data",
        "options": {}
      },
      "id": "split-partners",
      "name": "Split Partners",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "fromEmail": "andrew@prolnk.io",
        "fromName": "Andrew at ProLnk",
        "toEmail": "={{ $json.email }}",
        "subject": "We miss you, {{ $json.businessName }} — here's what you've been missing",
        "emailType": "html",
        "message": "<html><body style='font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;'><h2>Hi {{ $json.businessName }},</h2><p>It's been a while since we've seen you on ProLnk. Since you last logged in, there have been <strong>{{ $json.missedOpportunities }} opportunities</strong> in your service area that went to other partners.</p>{% if $json.lastCommissionAmount %}<p>Your last commission was <strong>${{ $json.lastCommissionAmount }}</strong>. There's more where that came from.</p>{% endif %}<p>It only takes 30 seconds to log a job photo and let our AI do the rest.</p><a href='https://prolnk.io/field-os' style='display: inline-block; background: #0A1628; color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: bold;'>Log a Job Now →</a><p style='color: #666; font-size: 14px; margin-top: 24px;'>If you've moved or changed trades, reply and let me know — I'll update your profile. — Andrew</p></body></html>"
      },
      "id": "send-winback-email",
      "name": "Send Win-Back Email",
      "type": "n8n-nodes-base.sendEmail",
      "typeVersion": 2,
      "position": [900, 300],
      "credentials": { "smtp": { "id": "smtp-credentials", "name": "SMTP / SendGrid" } }
    }
  ],
  "connections": {
    "Daily Trigger": { "main": [[{ "node": "Fetch 60-Day Inactive Partners", "type": "main", "index": 0 }]] },
    "Fetch 60-Day Inactive Partners": { "main": [[{ "node": "Split Partners", "type": "main", "index": 0 }]] },
    "Split Partners": { "main": [[{ "node": "Send Win-Back Email", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "meta": {
    "prolnk": {
      "version": "1.0",
      "trigger_type": "scheduled_daily",
      "notes": "Runs daily, queries ProLnk API for partners inactive 60+ days, sends personalized win-back email. Set PROLNK_API_KEY in n8n credentials."
    }
  }
}
