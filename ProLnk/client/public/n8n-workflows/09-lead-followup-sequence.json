{
  "name": "ProLnk — Lead Follow-Up Sequence (3-Touch)",
  "description": "Automatically sends a 3-touch follow-up sequence (immediate email, 24h SMS, 48h email) when a new opportunity is dispatched to a receiving partner. Stops the sequence if the partner accepts or declines the lead.",
  "version": "1.0.0",
  "tags": ["prolnk", "leads", "follow-up", "email", "sms"],
  "nodes": [
    {
      "id": "trigger",
      "name": "Webhook — New Lead Dispatched",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300],
      "parameters": {
        "path": "prolnk-lead-dispatched",
        "method": "POST",
        "responseMode": "onReceived",
        "responseData": "{ \"received\": true }"
      },
      "notes": "Called by ProLnk server when a lead is dispatched. Payload: { opportunityId, partnerEmail, partnerName, partnerPhone, opportunityType, estimatedJobValue, leadExpiresAt, acceptUrl, declineUrl }"
    },
    {
      "id": "set_vars",
      "name": "Set Variables",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [300, 300],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "opportunityId",    "value": "={{ $json.opportunityId }}", "type": "string" },
            { "name": "partnerEmail",     "value": "={{ $json.partnerEmail }}",  "type": "string" },
            { "name": "partnerName",      "value": "={{ $json.partnerName }}",   "type": "string" },
            { "name": "partnerPhone",     "value": "={{ $json.partnerPhone }}",  "type": "string" },
            { "name": "opportunityType",  "value": "={{ $json.opportunityType }}", "type": "string" },
            { "name": "estimatedValue",   "value": "={{ $json.estimatedJobValue }}", "type": "string" },
            { "name": "acceptUrl",        "value": "={{ $json.acceptUrl }}",     "type": "string" },
            { "name": "declineUrl",       "value": "={{ $json.declineUrl }}",    "type": "string" },
            { "name": "expiresAt",        "value": "={{ $json.leadExpiresAt }}", "type": "string" }
          ]
        }
      }
    },
    {
      "id": "touch1_email",
      "name": "Touch 1 — Immediate Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [500, 200],
      "parameters": {
        "fromEmail": "leads@prolnk.com",
        "toEmail": "={{ $vars.partnerEmail }}",
        "subject": "🔔 New Lead: {{ $vars.opportunityType }} — Est. ${{ $vars.estimatedValue }}",
        "emailType": "html",
        "message": "<h2>New Referral Lead</h2><p>Hi {{ $vars.partnerName }},</p><p>A new <strong>{{ $vars.opportunityType }}</strong> lead has been routed to you with an estimated job value of <strong>${{ $vars.estimatedValue }}</strong>.</p><p>This lead expires in 24 hours. Act fast!</p><p><a href='{{ $vars.acceptUrl }}' style='background:#0A1628;color:white;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:bold;'>✅ Accept Lead</a>&nbsp;&nbsp;<a href='{{ $vars.declineUrl }}' style='background:#f3f4f6;color:#374151;padding:12px 24px;border-radius:8px;text-decoration:none;'>Decline</a></p><p style='color:#6b7280;font-size:12px;'>ProLnk Partner Network — DFW</p>"
      }
    },
    {
      "id": "wait_24h",
      "name": "Wait 24 Hours",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [500, 400],
      "parameters": {
        "resume": "timeInterval",
        "unit": "hours",
        "amount": 24
      }
    },
    {
      "id": "check_status_1",
      "name": "Check Lead Status (24h)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [700, 400],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.PROLNK_API_URL }}/api/trpc/admin.getOpportunityStatus?input={\"id\":{{ $vars.opportunityId }}}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      }
    },
    {
      "id": "still_pending_1",
      "name": "Still Pending?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 400],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.result?.data?.status }}",
              "rightValue": "sent",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      }
    },
    {
      "id": "touch2_sms",
      "name": "Touch 2 — 24h SMS Reminder",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [1100, 300],
      "parameters": {
        "operation": "send",
        "from": "={{ $env.TWILIO_FROM_NUMBER }}",
        "to": "={{ $vars.partnerPhone }}",
        "message": "ProLnk: Your {{ $vars.opportunityType }} lead expires soon! Est. value ${{ $vars.estimatedValue }}. Accept now: {{ $vars.acceptUrl }}"
      }
    },
    {
      "id": "wait_48h",
      "name": "Wait Another 24 Hours",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1100, 500],
      "parameters": {
        "resume": "timeInterval",
        "unit": "hours",
        "amount": 24
      }
    },
    {
      "id": "check_status_2",
      "name": "Check Lead Status (48h)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1300, 500],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.PROLNK_API_URL }}/api/trpc/admin.getOpportunityStatus?input={\"id\":{{ $vars.opportunityId }}}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      }
    },
    {
      "id": "still_pending_2",
      "name": "Still Pending? (48h)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1500, 500],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.result?.data?.status }}",
              "rightValue": "sent",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      }
    },
    {
      "id": "touch3_email",
      "name": "Touch 3 — 48h Final Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [1700, 400],
      "parameters": {
        "fromEmail": "leads@prolnk.com",
        "toEmail": "={{ $vars.partnerEmail }}",
        "subject": "⚠️ Last Chance: Lead Expiring Soon",
        "emailType": "html",
        "message": "<h2>Final Reminder</h2><p>Hi {{ $vars.partnerName }},</p><p>Your <strong>{{ $vars.opportunityType }}</strong> lead is about to expire. If not accepted, it will be routed to another partner in the network.</p><p><a href='{{ $vars.acceptUrl }}' style='background:#EF4444;color:white;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:bold;'>⚡ Accept Before It Expires</a></p>"
      }
    },
    {
      "id": "end_accepted",
      "name": "End — Lead Already Accepted",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1100, 700],
      "parameters": {}
    }
  ],
  "connections": {
    "trigger":         { "main": [[{ "node": "set_vars",        "type": "main", "index": 0 }]] },
    "set_vars":        { "main": [[{ "node": "touch1_email",    "type": "main", "index": 0 }, { "node": "wait_24h", "type": "main", "index": 0 }]] },
    "wait_24h":        { "main": [[{ "node": "check_status_1", "type": "main", "index": 0 }]] },
    "check_status_1":  { "main": [[{ "node": "still_pending_1","type": "main", "index": 0 }]] },
    "still_pending_1": {
      "main": [
        [{ "node": "touch2_sms", "type": "main", "index": 0 }, { "node": "wait_48h", "type": "main", "index": 0 }],
        [{ "node": "end_accepted", "type": "main", "index": 0 }]
      ]
    },
    "wait_48h":        { "main": [[{ "node": "check_status_2", "type": "main", "index": 0 }]] },
    "check_status_2":  { "main": [[{ "node": "still_pending_2","type": "main", "index": 0 }]] },
    "still_pending_2": {
      "main": [
        [{ "node": "touch3_email", "type": "main", "index": 0 }],
        [{ "node": "end_accepted", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "meta": {
    "templateCredsSetupCompleted": false
  }
}
