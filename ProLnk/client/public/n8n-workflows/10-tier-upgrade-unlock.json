{
  "name": "ProLnk — Tier Upgrade Notification + Feature Unlock",
  "description": "Triggered when a partner's tier is upgraded in the ProLnk platform. Sends a congratulations email with new benefits, unlocks the partner's Stripe subscription tier, and notifies the admin.",
  "version": "1.0.0",
  "tags": ["prolnk", "tier", "upgrade", "stripe", "email"],
  "nodes": [
    {
      "id": "trigger",
      "name": "Webhook — Partner Tier Upgraded",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300],
      "parameters": {
        "path": "prolnk-tier-upgrade",
        "method": "POST",
        "responseMode": "onReceived",
        "responseData": "{ \"received\": true }"
      },
      "notes": "Payload: { partnerId, partnerEmail, partnerName, oldTier, newTier, newCommissionRate, newMonthlyFee, stripeCustomerId }"
    },
    {
      "id": "set_vars",
      "name": "Set Variables",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [300, 300],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "partnerId",         "value": "={{ $json.partnerId }}",         "type": "string" },
            { "name": "partnerEmail",      "value": "={{ $json.partnerEmail }}",      "type": "string" },
            { "name": "partnerName",       "value": "={{ $json.partnerName }}",       "type": "string" },
            { "name": "oldTier",           "value": "={{ $json.oldTier }}",           "type": "string" },
            { "name": "newTier",           "value": "={{ $json.newTier }}",           "type": "string" },
            { "name": "newCommissionRate", "value": "={{ $json.newCommissionRate }}", "type": "string" },
            { "name": "newMonthlyFee",     "value": "={{ $json.newMonthlyFee }}",     "type": "string" },
            { "name": "stripeCustomerId",  "value": "={{ $json.stripeCustomerId }}",  "type": "string" }
          ]
        }
      }
    },
    {
      "id": "congrats_email",
      "name": "Send Congratulations Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [500, 200],
      "parameters": {
        "fromEmail": "partners@prolnk.com",
        "toEmail": "={{ $vars.partnerEmail }}",
        "subject": "🎉 You've been upgraded to {{ $vars.newTier | upper }} tier!",
        "emailType": "html",
        "message": "<div style='font-family:sans-serif;max-width:600px;margin:0 auto;'><div style='background:#0A1628;padding:32px;border-radius:12px 12px 0 0;text-align:center;'><h1 style='color:#F5E642;margin:0;'>🎉 Tier Upgrade!</h1></div><div style='background:#ffffff;padding:32px;border-radius:0 0 12px 12px;'><p>Hi <strong>{{ $vars.partnerName }}</strong>,</p><p>Congratulations! Your ProLnk account has been upgraded from <strong>{{ $vars.oldTier | upper }}</strong> to <strong>{{ $vars.newTier | upper }}</strong> tier.</p><h3>Your New Benefits:</h3><ul><li>Commission rate: <strong>{{ $vars.newCommissionRate }}%</strong> keep rate</li><li>Priority lead routing in your service area</li><li>Advanced analytics dashboard access</li><li>Dedicated partner support line</li></ul><p><a href='{{ $env.APP_URL }}/dashboard' style='background:#0A1628;color:white;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:bold;'>View Your Dashboard →</a></p><p style='color:#6b7280;font-size:12px;margin-top:24px;'>ProLnk Partner Network — DFW</p></div></div>"
      }
    },
    {
      "id": "update_stripe_subscription",
      "name": "Update Stripe Subscription",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 400],
      "parameters": {
        "method": "POST",
        "url": "https://api.stripe.com/v1/subscriptions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "customer", "value": "={{ $vars.stripeCustomerId }}" },
            { "name": "items[0][price]", "value": "={{ $env['STRIPE_PRICE_' + $vars.newTier.toUpperCase()] }}" }
          ]
        }
      },
      "notes": "Set STRIPE_PRICE_PRO, STRIPE_PRICE_CREW, etc. in n8n environment variables"
    },
    {
      "id": "notify_admin",
      "name": "Notify Admin (Slack / Email)",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [700, 300],
      "parameters": {
        "fromEmail": "system@prolnk.com",
        "toEmail": "={{ $env.ADMIN_EMAIL }}",
        "subject": "[ProLnk] Partner Tier Upgrade: {{ $vars.partnerName }}",
        "emailType": "text",
        "message": "Partner {{ $vars.partnerName }} (ID: {{ $vars.partnerId }}) has been upgraded from {{ $vars.oldTier }} to {{ $vars.newTier }}.\n\nNew commission rate: {{ $vars.newCommissionRate }}%\nNew monthly fee: ${{ $vars.newMonthlyFee }}\n\nStripe customer: {{ $vars.stripeCustomerId }}"
      }
    },
    {
      "id": "log_upgrade",
      "name": "Log Upgrade to ProLnk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.PROLNK_API_URL }}/api/trpc/admin.logTierUpgrade",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={ \"partnerId\": {{ $vars.partnerId }}, \"oldTier\": \"{{ $vars.oldTier }}\", \"newTier\": \"{{ $vars.newTier }}\" }"
      }
    }
  ],
  "connections": {
    "trigger":                    { "main": [[{ "node": "set_vars",                   "type": "main", "index": 0 }]] },
    "set_vars":                   { "main": [[{ "node": "congrats_email",             "type": "main", "index": 0 }, { "node": "update_stripe_subscription", "type": "main", "index": 0 }]] },
    "congrats_email":             { "main": [[{ "node": "notify_admin",               "type": "main", "index": 0 }]] },
    "update_stripe_subscription": { "main": [[{ "node": "notify_admin",               "type": "main", "index": 0 }]] },
    "notify_admin":               { "main": [[{ "node": "log_upgrade",                "type": "main", "index": 0 }]] }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  }
}
