{
  "name": "ProLnk — 08 Partner NPS Survey (30-Day)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "prolnk-partner-30day",
        "responseMode": "onReceived"
      },
      "id": "webhook-trigger",
      "name": "Webhook — Partner 30-Day Mark",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "fromEmail": "feedback@prolnk.com",
        "toEmail": "={{ $json.partnerEmail }}",
        "subject": "Quick question — how's ProLnk working for you?",
        "emailFormat": "html",
        "message": "=<div style='font-family:Inter,sans-serif;max-width:600px;margin:0 auto;'><h2 style='color:#0A1628;'>You've been with us for 30 days 🎉</h2><p>We'd love to know how things are going. One question:</p><p style='font-size:18px;font-weight:600;color:#0A1628;'>How likely are you to recommend ProLnk to another home service professional?</p><div style='display:flex;gap:8px;margin:20px 0;flex-wrap:wrap;'><a href='https://prolnk.manus.space/nps?score=1&partner={{ $json.partnerId }}' style='background:#F4F6FA;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>1</a><a href='https://prolnk.manus.space/nps?score=2&partner={{ $json.partnerId }}' style='background:#F4F6FA;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>2</a><a href='https://prolnk.manus.space/nps?score=3&partner={{ $json.partnerId }}' style='background:#F4F6FA;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>3</a><a href='https://prolnk.manus.space/nps?score=4&partner={{ $json.partnerId }}' style='background:#F4F6FA;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>4</a><a href='https://prolnk.manus.space/nps?score=5&partner={{ $json.partnerId }}' style='background:#F4F6FA;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>5</a><a href='https://prolnk.manus.space/nps?score=6&partner={{ $json.partnerId }}' style='background:#F4F6FA;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>6</a><a href='https://prolnk.manus.space/nps?score=7&partner={{ $json.partnerId }}' style='background:#0A1628;color:#fff;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>7</a><a href='https://prolnk.manus.space/nps?score=8&partner={{ $json.partnerId }}' style='background:#0A1628;color:#fff;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>8</a><a href='https://prolnk.manus.space/nps?score=9&partner={{ $json.partnerId }}' style='background:#F5E642;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>9</a><a href='https://prolnk.manus.space/nps?score=10&partner={{ $json.partnerId }}' style='background:#F5E642;color:#0A1628;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:600;'>10</a></div><p style='color:#666;font-size:13px;'>1 = Not at all likely &nbsp;&nbsp; 10 = Extremely likely</p></div>"
      },
      "id": "nps-email",
      "name": "Resend — NPS Survey Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [460, 300]
    }
  ],
  "connections": {
    "Webhook — Partner 30-Day Mark": {
      "main": [[{ "node": "Resend — NPS Survey Email", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["prolnk", "partner", "nps"],
  "_meta": {
    "description": "Fires when a partner reaches their 30-day anniversary. Sends a 1-10 NPS survey email with clickable score links. Payload: { partnerEmail, partnerId }. NPS score clicks should be captured by a /nps route in the app.",
    "setup": "1. Set Resend env vars. 2. Wire webhook in ProLnk admin → Webhooks → Partner 30-Day. 3. Build /nps route in app to capture scores. 4. Activate."
  }
}
