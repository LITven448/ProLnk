{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*"],
  "exclude": [
    "node_modules", "build", "dist", "**/*.test.ts",
    "client/src/pages/admin/AnalyticsReal.tsx",
    "client/src/pages/admin/BrainTrustDashboard.tsx",
    "client/src/pages/admin/BriefcaseAdmin.tsx",
    "client/src/pages/admin/CommissionDisputeCenter.tsx",
    "client/src/pages/admin/NotificationCenter.tsx",
    "client/src/pages/admin/PlatformHealthDashboard.tsx",
    "client/src/pages/admin/ScoutDashboard.tsx",
    "client/src/pages/admin/WaitlistManagerNew.tsx",
    "client/src/pages/BidBoardPage.tsx",
    "client/src/pages/BriefcaseManager.tsx",
    "client/src/pages/FoundingPartnerPage.tsx",
    "client/src/pages/homeowner/RenderingConversation.tsx",
    "client/src/pages/IntegrationSettingsPage.tsx",
    "client/src/pages/media/ProLnkMediaSite.tsx",
    "client/src/pages/PartnerOnboardingWizard.tsx",
    "client/src/pages/ProPassManager.tsx",
    "client/src/pages/ProPassVerify.tsx",
    "client/src/pages/PublicBriefcaseVerify.tsx",
    "client/src/pages/ScoutAssessmentWizard.tsx",
    "server/agents/managingTierAgents.ts",
    "server/agents/subAgents.ts"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
